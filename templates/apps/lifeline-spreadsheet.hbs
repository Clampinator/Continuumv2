<div class="lss-wrap">

  <!-- TOOLBAR -->
  <div class="lss-toolbar">
    <button class="lss-sort-toggle" eventTitle="Toggle age sort direction">
      {{#if sortNewestFirst}}<i class="fas fa-arrow-down"></i> Age: Newest First{{else}}<i class="fas fa-arrow-up"></i> Age: Oldest First{{/if}}
    </button>
    <button class="lss-bulk-shift-btn" eventTitle="Shift objective time for selected events"><i class="fas fa-clock"></i> Bulk Shift</button>
    <button class="lss-import-btn"   eventTitle="Import events from a CSV file"><i class="fas fa-file-import"></i> Import CSV</button>
    <button class="lss-export-btn"   eventTitle="Export all events as a CSV file"><i class="fas fa-file-export"></i> Export CSV</button>
    <button class="lss-template-btn" eventTitle="Download a blank CSV template to fill in"><i class="fas fa-file-download"></i> Get Template</button>
    <span class="lss-count">{{rows.length}} event{{#unless (eq rows.length 1)}}s{{/unless}}</span>
  </div>

  <!-- SCROLLING TABLE -->
  <div class="lss-scroll">
    <table>
      <thead>
        <tr>
          <th style="width:24px"><input type="checkbox" class="lss-select-all" eventTitle="Select all events"/></th>
          <th style="width:24px"></th>
          <th style="width:95px">Date</th>
          <th style="width:65px">Time</th>
          <th style="min-width:180px">eventTitle</th>
          <th style="min-width:240px">eventNotes</th>
          <th style="min-width:150px">Location</th>
          <th style="width:100px">Era</th>
          <th style="width:120px">Experience</th>
          <th style="width:60px">Type</th>
          <th style="width:70px"></th>
        </tr>
      </thead>
      <tbody>

        <!-- NEW ROW FORM -->
        <tr class="lss-new-row-tr">
          <td colspan="11">
            <form class="lss-new-form" autocomplete="off">
              <div style="display:flex; gap:4px; align-items:center; flex-wrap:wrap;">
                <input class="lss-field lss-n-date"     style="width:95px"  placeholder="YYYY-MM-DD" eventTitle="Date (required)"/>
                <input class="lss-field lss-n-time"     style="width:65px"  placeholder="HH:MM"      eventTitle="Time (optional)"/>
                <input class="lss-field lss-n-eventTitle"    style="min-width:180px; flex:1;" placeholder="eventTitle" eventTitle="eventTitle"/>
                <input class="lss-field lss-n-eventNotes"    style="min-width:240px; flex:2;" placeholder="eventNotes" eventTitle="eventNotes"/>
                <input class="lss-field lss-n-location" style="min-width:150px; flex:1;" placeholder="Location" eventTitle="Location"/>
                <button type="button" class="lss-map-pin-btn" eventTitle="Pin location to map"><i class="fas fa-map-marker-alt"></i></button>
                <label class="lss-check-label" eventTitle="Expand for span and experience options">
                  <input type="checkbox" class="lss-n-is-span"/> Span
                </label>
                <button type="button" class="lss-add-btn"><i class="fas fa-plus"></i> Add</button>
              </div>

              <!-- Span fields (hidden until checkbox checked) -->
              <div class="lss-new-span-fields hidden" style="margin-top:6px; padding:6px; border:1px solid #3a4a5a; border-radius:3px; background:#16202a;">
                <div class="lss-section-label">Span Details</div>
                <div class="lss-span-row">
                  <span class="lss-span-label">From:</span>
                  <input class="lss-field lss-n-sf-date" style="width:95px" placeholder="YYYY-MM-DD"/>
                  <input class="lss-field lss-n-sf-time" style="width:65px" placeholder="HH:MM"/>
                  <input class="lss-field lss-n-sf-loc"  style="min-width:160px; flex:1"     placeholder="Departure location"/>
                </div>
                <div class="lss-span-row">
                  <span class="lss-span-label">To:</span>
                  <input class="lss-field lss-n-st-date" style="width:95px" placeholder="YYYY-MM-DD"/>
                  <input class="lss-field lss-n-st-time" style="width:65px" placeholder="HH:MM"/>
                  <input class="lss-field lss-n-st-loc"  style="min-width:160px; flex:1"     placeholder="Arrival location"/>
                </div>
              </div>

              <!-- Experience options -->
              <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:6px;">
                <label class="lss-check-label"><input type="checkbox" class="lss-n-start-exp"/> Start new Experience</label>
                <div class="lss-new-exp-name-wrap hidden">
                  <input class="lss-field lss-n-exp-name" style="width:140px" placeholder="Experience name"/>
                </div>
                {{#if allExperiences}}
                <label class="lss-check-label" style="margin-left:8px;">Within:
                  <select class="lss-field lss-n-exp-select" style="width:140px; margin-left:4px;">
                    <option value="">-- Era Level --</option>
                    {{#each allExperiences}}
                    <option value="{{eraId}}:{{expId}}">{{name}}{{#unless isOpen}} [Closed]{{/unless}}</option>
                    {{/each}}
                  </select>
                </label>
                <label class="lss-check-label"><input type="checkbox" class="lss-n-end-exp"/> End Experience</label>
                <div class="lss-new-end-exp-wrap hidden">
                  <select class="lss-field lss-n-end-exp-which" style="width:140px;">
                    {{#each allExperiences}}{{#if isOpen}}
                    <option value="{{eraId}}:{{expId}}">{{name}}</option>
                    {{/if}}{{/each}}
                  </select>
                </div>
                <label class="lss-check-label"><input type="checkbox" class="lss-n-reopen-exp"/> Re-open Experience</label>
                <div class="lss-new-reopen-wrap hidden">
                  <select class="lss-field lss-n-reopen-which" style="width:140px;">
                    {{#each allExperiences}}{{#unless isOpen}}
                    <option value="{{eraId}}:{{expId}}">{{name}}</option>
                    {{/unless}}{{/each}}
                  </select>
                </div>
                {{/if}}
              </div>
            </form>
          </td>
        </tr>

        <tr style="height:4px; background:#111;"><td colspan="11"></td></tr>

        <!-- EXISTING EVENT ROWS -->
        {{#each rows}}
        <tr class="lss-event-row{{#if eventIsSpan}} is-span{{/if}}"
            data-event-id="{{eventId}}"
            data-era-id="{{eraId}}"
            data-exp-id="{{expId}}">
           <td><input type="checkbox" class="lss-row-select" data-event-id="{{eventId}}"/></td>
           <td><i class="fas fa-grip-vertical lss-drag-handle"></i></td>
           <td><input class="lss-field lss-field-date" data-field="date" value="{{date}}" placeholder="YYYY-MM-DD"/></td>
          <td><input class="lss-field lss-field-time" data-field="time" value="{{time}}" placeholder="HH:MM"/></td>
          <td><input class="lss-field lss-field-eventTitle" data-field="eventTitle" value="{{eventTitle}}" placeholder="eventTitle"/></td>
          <td><input class="lss-field lss-field-eventNotes" data-field="eventNotes" value="{{eventNotes}}" placeholder="eventNotes"/></td>
           <td style="display:flex; align-items:center; gap:2px;">
             <input class="lss-field lss-field-location" data-field="location" value="{{location}}" placeholder="Location" style="flex:1;"/>
             <button type="button" class="lss-map-pin-btn lss-row-map-pin-btn" eventTitle="Pin location to map"><i class="fas fa-map-marker-alt"></i></button>
           </td>
          <td><span class="lss-era-badge">{{eraName}}</span></td>
          <td><span class="lss-exp-badge">{{#if expName}}{{expName}}{{else}}--{{/if}}</span></td>
          <td><span class="lss-type-label">{{typeLabel}}</span></td>
          <td style="white-space:nowrap;">
            <button class="lss-action-btn lss-expand-btn" eventTitle="More options">
              <i class="fas fa-chevron-{{#if isExpanded}}up{{else}}down{{/if}}"></i>
            </button>
            <button class="lss-action-btn lss-delete-btn" eventTitle="Delete event"><i class="fas fa-trash"></i></button>
          </td>
        </tr>

        <!-- EXPANDED SECTION for this row -->
        <tr class="lss-expanded-row{{#unless isExpanded}} hidden{{/unless}}"
             data-event-id="{{eventId}}" data-era-id="{{eraId}}" data-exp-id="{{expId}}">
           <td colspan="11">
            <div class="lss-expand-inner">

              <!-- Span toggle + fields -->
              <label class="lss-check-label">
                <input type="checkbox" class="lss-is-span" {{#if eventIsSpan}}checked{{/if}}/>
                This event is a Span (journey with departure and arrival)
              </label>

              <div class="lss-span-section lss-span-fields-section{{#unless eventIsSpan}} hidden{{/unless}}">
                <div class="lss-span-row">
                  <span class="lss-span-label">From:</span>
                  <input class="lss-field lss-sf-date" value="{{eventSpanFromDate}}" style="width:95px" placeholder="YYYY-MM-DD"/>
                  <input class="lss-field lss-sf-time" value="{{eventSpanFromTime}}" style="width:65px" placeholder="HH:MM"/>
                  <input class="lss-field lss-sf-loc"  value="{{eventSpanFromLocation}}" style="min-width:160px; flex:1" placeholder="Departure location"/>
                </div>
                <div class="lss-span-row">
                  <span class="lss-span-label">To:</span>
                  <input class="lss-field lss-st-date" value="{{eventSpanToDate}}" style="width:95px" placeholder="YYYY-MM-DD"/>
                  <input class="lss-field lss-st-time" value="{{eventSpanToTime}}" style="width:65px" placeholder="HH:MM"/>
                  <input class="lss-field lss-st-loc"  value="{{eventSpanToLocation}}" style="min-width:160px; flex:1" placeholder="Arrival location"/>
                </div>
              </div>

              <!-- Experience controls -->
              <div class="lss-exp-section">
                {{#if ../allEras}}
                <div>
                  <div class="lss-section-label">Era placement</div>
                  <select class="lss-field lss-age-select" style="width:200px; margin-top:3px;">
                    {{#each ../allEras}}
                    <option value="{{eraId}}">{{name}}</option>
                    {{/each}}
                  </select>
                </div>
                {{/if}}
                <div>
                  <div class="lss-section-label">Experience placement</div>
                  <select class="lss-field lss-exp-select" style="width:200px; margin-top:3px;">
                    <option value="">-- Era Level (no experience) --</option>
                    {{#each ../allExperiences}}
                    <option value="{{eraId}}:{{expId}}">{{name}}{{#unless isOpen}} [Closed]{{/unless}}</option>
                    {{/each}}
                  </select>
                </div>
                <div>
                  <label class="lss-check-label" style="margin-top:4px;">
                    <input type="checkbox" class="lss-start-exp"/> Start new Experience at this event
                  </label>
                  <div class="lss-exp-name-wrap hidden" style="margin-top:3px;">
                    <input class="lss-field lss-exp-name-input" style="width:180px" placeholder="Experience name"/>
                  </div>
                </div>
                {{#if ../allExperiences}}
                <div>
                  <label class="lss-check-label">
                    <input type="checkbox" class="lss-end-exp"/> End an Experience at this event
                  </label>
                  <div class="lss-end-exp-wrap hidden" style="margin-top:3px;">
                    <select class="lss-field lss-end-exp-which" style="width:180px;">
                      {{#each ../allExperiences}}{{#if isOpen}}
                      <option value="{{eraId}}:{{expId}}">{{name}}</option>
                      {{/if}}{{/each}}
                    </select>
                  </div>
                </div>
                <div>
                  <label class="lss-check-label">
                    <input type="checkbox" class="lss-reopen-exp"/> Re-open a closed Experience
                  </label>
                  <div class="lss-reopen-wrap hidden" style="margin-top:3px;">
                    <select class="lss-field lss-reopen-which" style="width:180px;">
                      {{#each ../allExperiences}}{{#unless isOpen}}
                      <option value="{{eraId}}:{{expId}}">{{name}}</option>
                      {{/unless}}{{/each}}
                    </select>
                  </div>
                </div>
                {{/if}}
              </div>

              <button type="button" class="lss-save-row-btn"><i class="fas fa-save"></i> Save Changes</button>
            </div>
          </td>
        </tr>

        {{/each}}

        {{#unless rows}}
        <tr><td colspan="11" style="text-align:center; color:#666; padding:20px; font-style:italic;">
          No events yet. Use the form above to add your first event.
        </td></tr>
        {{/unless}}

      </tbody>
    </table>
  </div>
</div>
